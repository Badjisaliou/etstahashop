{
  "name": "etstahashop-admin-desktop",
  "private": true,
  "version": "0.1.1",
  "description": "Application de bureau ETS Taha Shop Admin",
  "author": "ETS Taha Shop",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:web": "npm --prefix ../admin run dev",
    "dev:desktop": "wait-on tcp:127.0.0.1:5174 && electron .",
    "dev": "concurrently -k -n WEB,DESKTOP -c cyan,yellow \"npm run dev:web\" \"npm run dev:desktop\"",
    "build:web": "cross-env VITE_APP_BASE=./ npm --prefix ../admin run build",
    "sync:web-dist": "node ./scripts/sync-admin-dist.mjs",
    "build": "npm run build:web && npm run sync:web-dist && electron-builder",
    "build:dir": "npm run build:web && npm run sync:web-dist && electron-builder --dir",
    "release:win": "npm run build:web && npm run sync:web-dist && electron-builder --win --publish never",
    "release:publish": "npm run build:web && npm run sync:web-dist && electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.etstaha.admin.desktop",
    "productName": "ETS Taha Admin",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "build/icons/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "electron/**/*",
      "web-dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://downloads.etstahashop.com/admin-desktop/"
      }
    ],
    "nsis": {
      "shortcutName": "ETS Taha Admin",
      "createDesktopShortcut": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico"
    }
  }
}
