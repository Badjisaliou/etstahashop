APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:yourkeyhere
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174,https://etstahashop.vercel.app,https://etstahashop.com,https://etstahashopamin.vercel.app,null
CORS_SUPPORTS_CREDENTIALS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ets_taha_shop
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=failover
CATALOG_CACHE_TTL_SECONDS=300

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_NOTIFICATION_ADDRESS=

WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=meta
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ADMIN_NUMBER=
WHATSAPP_TIMEOUT_SECONDS=10
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=products/uploads

PAYMENT_WAVE_LABEL=Wave
PAYMENT_WAVE_ACCOUNT_NAME="ETS Taha Shop"
PAYMENT_WAVE_ACCOUNT_NUMBER=
PAYMENT_WAVE_INSTRUCTIONS="Effectuez le transfert Wave puis conservez la reference."
PAYMENT_ORANGE_MONEY_LABEL="Orange Money"
PAYMENT_ORANGE_MONEY_ACCOUNT_NAME="ETS Taha Shop"
PAYMENT_ORANGE_MONEY_ACCOUNT_NUMBER=
PAYMENT_ORANGE_MONEY_INSTRUCTIONS="Effectuez le transfert Orange Money puis conservez la reference."

VITE_APP_NAME="${APP_NAME}"
