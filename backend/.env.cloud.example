APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.example.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
MEDIA_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CATALOG_CACHE_TTL_SECONDS=300

REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_NOTIFICATION_ADDRESS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

PAYMENT_WAVE_LABEL=Wave
PAYMENT_WAVE_ACCOUNT_NAME="ETS Taha Shop"
PAYMENT_WAVE_ACCOUNT_NUMBER=
PAYMENT_WAVE_INSTRUCTIONS="Effectuez le transfert Wave puis conservez la reference."
PAYMENT_ORANGE_MONEY_LABEL="Orange Money"
PAYMENT_ORANGE_MONEY_ACCOUNT_NAME="ETS Taha Shop"
